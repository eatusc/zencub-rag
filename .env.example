NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
OPENAI_API_KEY=replace_me
OPENROUTER_API_KEY=replace_me

# Langfuse tracing (optional). Tracing is skipped when the keys are unset.
# Read by src/instrumentation.ts and src/lib/langfuseHandler.ts.
LANGFUSE_PUBLIC_KEY=replace_me
LANGFUSE_SECRET_KEY=replace_me
# Base URL of your Langfuse instance (self-hosted or https://cloud.langfuse.com)
LANGFUSE_BASEURL=http://localhost:3010

# Direct Postgres or pooler URL; this is not NEXT_PUBLIC_SUPABASE_URL.
LANGGRAPH_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
LANGGRAPH_CHECKPOINT_SCHEMA=langgraph
LANGGRAPH_TEST_MODE=off

RAG_ANALYZE_MODEL=gpt-4o-mini
RAG_ANSWER_MODEL=gpt-4o-mini
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_RERANK_MODEL=gpt-4o-mini
RAG_OPENROUTER_MODEL=qwen/qwen3-235b-a22b-2507
# Optional override; defaults to https://openrouter.ai/api/v1
RAG_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Set RAG_RERANK=off to disable the Ask reranker
RAG_RERANK=on
# Local model served through an OpenAI-compatible endpoint (for example Ollama)
RAG_QWEN_BASE_URL=http://localhost:11434/v1
RAG_QWEN_MODEL=qwen3.6:35b-mlx
# Optional local-CLI provider: Claude Code binary; empty model uses the CLI default
RAG_CLAUDE_BIN=claude
RAG_CLAUDE_MODEL=
# Safety guard: embed:chunks refuses to write unless the Supabase host matches this ref
RAG_TEST_PROJECT_REF=YOUR_PROJECT_REF

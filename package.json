{
  "name": "zencub-rag",
  "version": "0.1.0",
  "private": true,
  "description": "A RAG app for BJJ video transcripts: hybrid (keyword + semantic) retrieval with Reciprocal Rank Fusion, LLM reranking, and citation-backed generated answers, built on Next.js, Supabase/pgvector, and OpenAI.",
  "keywords": [
    "rag",
    "retrieval-augmented-generation",
    "semantic-search",
    "vector-search",
    "pgvector",
    "supabase",
    "nextjs",
    "openai",
    "reranking"
  ],
  "author": "Eric Lai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eatusc/zencub-rag.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "eval:queries": "node --experimental-strip-types scripts/evaluate-rag-examples.ts",
    "embed:chunks": "node --experimental-strip-types scripts/embed-rag-chunks.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "lucide-react": "^0.562.0",
    "next": "^16.2.10",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "type": "module"
}
